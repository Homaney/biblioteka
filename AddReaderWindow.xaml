<Window x:Class="biblioteka.AddReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Добавить читателя"
        Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        FontFamily="Segoe UI, Inter"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Темная цветовая палитра -->
        <SolidColorBrush x:Key="PrimaryPurple" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="PrimaryPurpleDark" Color="#7C3AED"/>
        <SolidColorBrush x:Key="CardBackground" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="InputBackground" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#B0B0B0"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#666666"/>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для DatePicker (одна кликабельная иконка) -->
        <Style x:Key="DarkDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid>
                            <Grid.Resources>
                                <!-- Стиль для внутреннего TextBox DatePicker -->
                                <Style TargetType="DatePickerTextBox">
                                    <Setter Property="Background" Value="{StaticResource InputBackground}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DatePickerTextBox">
                                                <Grid>
                                                    <TextBox x:Name="PART_TextBox" 
                                                             Background="Transparent"
                                                             Foreground="{StaticResource TextPrimary}"
                                                             BorderThickness="0"
                                                             Padding="12,0"
                                                             VerticalAlignment="Center"
                                                             IsReadOnly="True"
                                                             Text="{Binding SelectedDate, RelativeSource={RelativeSource AncestorType=DatePicker}, StringFormat=dd.MM.yyyy}"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>

                            <Border Background="{StaticResource InputBackground}"
                                    BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>

                                    <DatePickerTextBox Grid.Column="0" x:Name="PART_TextBox"/>

                                    <!-- Одна кликабельная кнопка с иконкой -->
                                    <ToggleButton x:Name="PART_Button" 
                                                  Grid.Column="1"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Width="42"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Cursor="Hand">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="0,8,8,0">
                                                    <TextBlock Text="📅" 
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="18"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3A3A3A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Background" Value="#3A3A3A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup" 
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Slide">
                                <Border Background="{StaticResource CardBackground}"
                                        BorderBrush="{StaticResource CardBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,5,0,0">
                                    <Calendar x:Name="PART_Calendar" 
                                              Background="{StaticResource CardBackground}"
                                              Foreground="{StaticResource TextPrimary}"
                                              BorderThickness="0"
                                              DisplayDate="{Binding SelectedDate, RelativeSource={RelativeSource TemplatedParent}}"
                                              SelectedDate="{Binding SelectedDate, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Calendar.Resources>
                                            <Style TargetType="CalendarDayButton">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryPurple}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryPurple}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Calendar.Resources>
                                    </Calendar>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для TextBlock с иконкой -->
        <Style x:Key="IconLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Стиль для кнопки -->
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#00B894"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00A884"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Margin="20" Background="#1E1E1E" CornerRadius="12" BorderBrush="#333333" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25">
                <TextBlock Text="👤 Добавление читателя"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryPurple}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <!-- Основная информация -->
                <TextBlock Text="👤 ФИО" Style="{StaticResource IconLabel}"/>
                <TextBox x:Name="FullNameBox"
                         Style="{StaticResource RoundedTextBox}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="📞 Телефон" Style="{StaticResource IconLabel}"/>
                <TextBox x:Name="PhoneBox"
                         Style="{StaticResource RoundedTextBox}"
                         Margin="0,0,0,16"
                         GotFocus="PhoneBox_GotFocus"
                         PreviewTextInput="PhoneBox_PreviewTextInput"/>

                <TextBlock Text="🏠 Адрес" Style="{StaticResource IconLabel}"/>
                <TextBox x:Name="AddressBox"
                         Style="{StaticResource RoundedTextBox}"
                         Margin="0,0,0,16"/>

                <!-- Даты -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🎂 Дата рождения" Style="{StaticResource IconLabel}"/>
                        <!-- Убраны все ограничения из XAML, теперь управляем через код -->
                        <DatePicker x:Name="BirthDatePicker"
                                    Style="{StaticResource DarkDatePicker}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="📅 Дата регистрации" Style="{StaticResource IconLabel}"/>
                        <DatePicker x:Name="RegistrationDatePicker"
                                    Style="{StaticResource DarkDatePicker}"
                                    DisplayDateEnd="{x:Static sys:DateTime.Today}"/>
                    </StackPanel>
                </Grid>

                <!-- Кнопка добавления -->
                <Button Content="✅ Добавить читателя"
                        Style="{StaticResource SuccessButton}"
                        HorizontalAlignment="Stretch"
                        Margin="0,10,0,0"
                        Click="AddReader_Click"/>

                <TextBlock Text="Все поля обязательны для заполнения"
                           Foreground="#666666"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>