<Window x:Class="biblioteka.EditWriteOffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактировать акт списания"
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F"
        FontFamily="Segoe UI"
        ResizeMode="NoResize">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryPurple" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="Success" Color="#10B981"/>
        <SolidColorBrush x:Key="CardBackground" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A1A1AA"/>
        <SolidColorBrush x:Key="InputBackground" Color="#2A2A2A"/>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryPurple}"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Success}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="✏️ Редактирование акта списания" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Номер акта:" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="ActNumberBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>
            <TextBlock Text="Дата списания:" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
            <DatePicker x:Name="WriteOffDatePicker" Height="36" Margin="0,0,0,15"/>
            <TextBlock Text="Причина:" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="ReasonBox" Style="{StaticResource ModernTextBox}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,15"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Выберите экземпляры для списания:" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
        <ListBox x:Name="InstancesListBox" Grid.Row="2" Margin="0,0,0,10" SelectionMode="Multiple"
                 Background="{StaticResource InputBackground}" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4,2">
                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="5,0,10,0"/>
                        <TextBlock Text="{Binding InventoryNumber}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text=" • " Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding BookTitle}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="3" Content="💾 Сохранить изменения" Style="{StaticResource SuccessButton}" Width="200" Click="SaveButton_Click" HorizontalAlignment="Right"/>
    </Grid>
</Window>