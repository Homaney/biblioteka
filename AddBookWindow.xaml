<Window x:Class="biblioteka.AddBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить книгу"
        Height="680" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F"
        FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Цветовая палитра (без изменений) -->
        <SolidColorBrush x:Key="PrimaryPurple" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="PrimaryPurpleDark" Color="#7C3AED"/>
        <SolidColorBrush x:Key="Success" Color="#10B981"/>
        <SolidColorBrush x:Key="SuccessDark" Color="#059669"/>
        <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerDark" Color="#DC2626"/>
        <SolidColorBrush x:Key="Info" Color="#3B82F6"/>
        <SolidColorBrush x:Key="InfoDark" Color="#2563EB"/>
        <SolidColorBrush x:Key="Background" Color="#0F0F0F"/>
        <SolidColorBrush x:Key="CardBackground" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A1A1AA"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#71717A"/>

        <!-- Стили (без изменений) -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252525"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#404040"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryPurple}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryPurpleDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Success}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SuccessDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryPurple}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="10,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaceholderTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" 
                                              Margin="10,0"
                                              VerticalAlignment="Center"/>
                                <TextBlock x:Name="placeholderText"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{StaticResource TextTertiary}"
                                           Margin="10,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NumericButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252525"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DropdownButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="AddButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{StaticResource Success}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Success}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="RemoveButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <TextBlock Text="×" 
                                      FontSize="14" 
                                      FontWeight="Bold"
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Danger}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryPurple}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border Margin="10" Background="{StaticResource CardBackground}" CornerRadius="8" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15">
                <!-- Заголовок -->
                <TextBlock Text="📖 Добавление книги" 
                          FontSize="20" 
                          FontWeight="Bold"
                          Foreground="{StaticResource TextPrimary}" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,12"/>

                <!-- ID книги -->
                <TextBlock Text="ID книги:" 
                          Foreground="{StaticResource TextSecondary}" 
                          FontSize="12" 
                          Margin="0,0,0,2"/>
                <TextBox x:Name="IdentifierBox" 
                        Style="{StaticResource PlaceholderTextBox}" 
                        Tag="Введите ID книги"
                        Margin="0,0,0,8"/>

                <!-- Название -->
                <TextBlock Text="Название:" 
                          Foreground="{StaticResource TextSecondary}" 
                          FontSize="12" 
                          Margin="0,0,0,2"/>
                <TextBox x:Name="TitleBox" 
                        Style="{StaticResource PlaceholderTextBox}" 
                        Tag="Введите название книги"
                        Margin="0,0,0,8"/>

                <!-- Авторы -->
                <TextBlock Text="Авторы:" 
                          Foreground="{StaticResource TextSecondary}" 
                          FontSize="12" 
                          Margin="0,0,0,2"/>

                <!-- Строка с кнопками и полем -->
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>

                    <!-- Поле ввода автора -->
                    <TextBox x:Name="AuthorInputBox" 
                            Style="{StaticResource PlaceholderTextBox}" 
                            Tag="Введите или выберите автора"
                            Grid.Column="0"
                            IsReadOnly="False"
                            Background="{StaticResource CardBackground}"
                            Cursor="IBeam"
                            Height="36"/>

                    <!-- Кнопка выпадающего списка -->
                    <Button x:Name="AuthorDropdownButton"
                            Content="▼" 
                            Style="{StaticResource DropdownButton}" 
                            Grid.Column="1"
                            Click="AuthorDropdown_Click"
                            ToolTip="Выбрать автора из списка"/>

                    <!-- Кнопка добавления автора -->
                    <Button x:Name="AddAuthorButton"
                            Content="+" 
                            Style="{StaticResource AddButton}" 
                            Grid.Column="3"
                            Click="AddAuthor_Click"
                            ToolTip="Добавить автора"/>
                </Grid>

                <!-- Выпадающий список авторов (Popup) -->
                <Popup x:Name="AuthorsPopup" 
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=AuthorInputBox}"
                       StaysOpen="False"
                       PopupAnimation="Slide"
                       AllowsTransparency="True"
                       Width="{Binding ElementName=AuthorInputBox, Path=ActualWidth}"
                       MaxHeight="160">
                    <Border Background="{StaticResource CardBackground}"
                            BorderBrush="{StaticResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Background="{StaticResource CardBackground}">
                            <ItemsControl x:Name="AuthorsListBox">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ListItemStyle}"
                                                MouseLeftButtonDown="AuthorItem_PreviewMouseDown"
                                                Tag="{Binding}">
                                            <TextBlock Text="{Binding}" 
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="12"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Popup>

                <!-- Список выбранных авторов -->
                <Border Background="{StaticResource CardBackground}" 
                        BorderBrush="{StaticResource CardBorder}" 
                        BorderThickness="1" 
                        Height="Auto" 
                        MinHeight="36"
                        MaxHeight="80"
                        Margin="0,2,0,8" 
                        Padding="4" 
                        CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SelectedAuthorsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252525" 
                                            CornerRadius="4" 
                                            Margin="0,1" 
                                            Padding="4,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="18"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding}" 
                                                      Foreground="{StaticResource TextPrimary}" 
                                                      FontSize="12"
                                                      VerticalAlignment="Center"/>
                                            <Button Content="×" 
                                                    Style="{StaticResource RemoveButton}" 
                                                    Click="RemoveAuthor_Click" 
                                                    Tag="{Binding}" 
                                                    Grid.Column="1"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- УДК -->
                <TextBlock Text="УДК:" 
                          Foreground="{StaticResource TextSecondary}" 
                          FontSize="12" 
                          Margin="0,0,0,2"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UDKDisplayBox" 
                            Style="{StaticResource PlaceholderTextBox}" 
                            Tag="Выберите УДК"
                            Grid.Column="0"
                            IsReadOnly="True"
                            Height="36"/>

                    <Button Content="▼" 
                            Style="{StaticResource DropdownButton}" 
                            Grid.Column="1"
                            Click="UDKDropdown_Click"
                            ToolTip="Выбрать УДК из списка"/>

                    <Button Content="Добавить" 
                            Style="{StaticResource PrimaryButton}" 
                            Grid.Column="3"
                            Click="AddUDKButton_Click"
                            Height="36"
                            Padding="6,0"/>
                </Grid>

                <!-- Выпадающий список УДК (Popup) -->
                <Popup x:Name="UDKPopup" 
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=UDKDisplayBox}"
                       StaysOpen="False"
                       PopupAnimation="Slide"
                       AllowsTransparency="True"
                       Width="{Binding ElementName=UDKDisplayBox, Path=ActualWidth}"
                       MaxHeight="160">
                    <Border Background="{StaticResource CardBackground}"
                            BorderBrush="{StaticResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Background="{StaticResource CardBackground}">
                            <ItemsControl x:Name="UDKListBox">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ListItemStyle}"
                                                MouseLeftButtonDown="UDKItem_PreviewMouseDown"
                                                Tag="{Binding}">
                                            <TextBlock Text="{Binding Code}" 
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="12"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Popup>

                <!-- Год издания -->
                <TextBlock Text="Год издания:" 
                          Foreground="{StaticResource TextSecondary}" 
                          FontSize="12" 
                          Margin="0,0,0,2"/>
                <TextBox x:Name="YearBox" 
                        Style="{StaticResource PlaceholderTextBox}" 
                        Tag="Введите год"
                        Margin="0,0,0,8"
                        Height="36"/>

                <!-- Количество экземпляров -->
                <TextBlock Text="Количество экземпляров:" 
                          Foreground="{StaticResource TextSecondary}" 
                          FontSize="12" 
                          Margin="0,0,0,2"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="−" 
                            Style="{StaticResource NumericButton}" 
                            Grid.Column="0"
                            Click="DecreaseQuantity_Click"
                            ToolTip="Уменьшить количество"/>

                    <TextBox x:Name="QuantityBox" 
                            Text="1" 
                            Style="{StaticResource ModernTextBox}" 
                            Grid.Column="2"
                            Height="28"
                            TextAlignment="Center"
                            PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <Button Content="+" 
                            Style="{StaticResource NumericButton}" 
                            Grid.Column="4"
                            Click="IncreaseQuantity_Click"
                            ToolTip="Увеличить количество"/>

                    <TextBlock Text="шт." 
                              Foreground="{StaticResource TextSecondary}" 
                              VerticalAlignment="Center" 
                              Grid.Column="5"
                              Margin="6,0,0,0"
                              FontSize="12"/>
                </Grid>

                <!-- Описание -->
                <TextBlock Text="Описание:" 
                          Foreground="{StaticResource TextSecondary}" 
                          FontSize="12" 
                          Margin="0,0,0,2"/>
                <TextBox x:Name="DescriptionBox" 
                        Style="{StaticResource PlaceholderTextBox}" 
                        Height="60" 
                        AcceptsReturn="True" 
                        TextWrapping="Wrap" 
                        Tag="Описание книги (необязательно)"
                        Margin="0,0,0,10"
                        VerticalContentAlignment="Top"
                        Padding="10,4"/>

                <!-- Кнопка добавления -->
                <Button Content="➕ Добавить книгу" 
                        Style="{StaticResource SuccessButton}"
                        Width="180" 
                        Height="40"
                        FontSize="14"
                        Click="AddBook_Click"
                        HorizontalAlignment="Center"
                        ToolTip="Добавить книгу в библиотеку"
                        Margin="0,0,0,5"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>