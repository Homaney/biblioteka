<Window x:Class="biblioteka.AddInstanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить экземпляр"
        Height="363" Width="350"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F0F"
        FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryPurple" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="Success" Color="#10B981"/>
        <SolidColorBrush x:Key="CardBackground" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A1A1AA"/>
        <SolidColorBrush x:Key="InputBackground" Color="#2A2A2A"/>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryPurple}"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Success}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </Window.Resources>

    <Border Margin="15" Background="{StaticResource CardBackground}" CornerRadius="8" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
        <StackPanel Margin="20">
            <TextBlock Text="📚 Добавление экземпляра" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

            <TextBlock Text="Количество:" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="QuantityBox" Text="1" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

            <TextBlock Text="Цена (BYN):" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="PriceBox" Text="0,00" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="✅ Добавить" Style="{StaticResource SuccessButton}" Width="120" Click="AddButton_Click" Margin="0,0,10,0"/>
                <Button Content="❌ Отмена" Width="100" Height="40" Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>